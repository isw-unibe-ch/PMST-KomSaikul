    {
      "name": "cells",
      "type": "table",
      "title": "Paradigm cells",
      "path": "pmst-komsaikul_cells.csv",
      "scheme": "file",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "schema": {
        "name": "cells-schema",
        "fields": [
          {
            "name": "cell_id",
            "type": "string",
            "title": "Cell identifier",
            "description": "The set of feature values as would appear in a gloss, separated by dots, eg. prs.ind.1sg or f.pl",
            "constraints": {
              "required": true,
              "unique": true,
              "pattern": "(excl|incl|nfut|aff|neg|fut|pl|sg|1|2|3)(\\.(excl|incl|nfut|aff|neg|fut|pl|sg|1|2|3))*"
            }
          },
          {
            "name": "POS",
            "type": "string",
            "title": "Part of Speech",
            "description": "The relevant part of speech for this item. This must refer to a PartOfSpeech entity from the lexinfo (https://lexinfo.net/) ontology. Multiple semi-colon separated values are allowed.",
            "constraints": {
              "pattern": "(interrogativeMultiplicativeNumeral|indefiniteMultiplicativeNumeral|interrogativeRelativePronoun|interrogativeCardinalNumeral|interrogativeOrdinalNumeral|reflexivePossessivePronoun|presentParticipleAdjective|irreflexivePersonalPronoun|fusedPrepositionDeterminer|possessiveRelativePronoun|indefiniteCardinalNumeral|indefiniteOrdinalNumeral|reflexivePersonalPronoun|subordinatingConjunction|interrogativeDeterminer|fusedPrepositionPronoun|pastParticipleAdjective|coordinatingConjunction|demonstrativeDeterminer|affixedPersonalPronoun|fusedPronounAuxiliary|strongPersonalPronoun|exclamativeDeterminer|multiplicativeNumeral|interrogativeParticle|demonstrativePronoun|coordinationParticle|indefiniteDeterminer|unclassifiedParticle|possessiveDeterminer|interrogativePronoun|conditionalParticle|prepositionalAdverb|compoundPreposition|comparativeParticle|distinctiveParticle|possessiveAdjective|superlativeParticle|reflexiveDeterminer|affirmativeParticle|weakPersonalPronoun|participleAdjective|presentativePronoun|possessiveParticle|infinitiveParticle|relativeDeterminer|existentialPronoun|generalizationWord|qualifierAdjective|exclamativePronoun|conditionalPronoun|possessivePronoun|collectivePronoun|reciprocalPronoun|indefinitePronoun|impersonalPronoun|indefiniteArticle|fusedPreposition|ordinalAdjective|partitiveArticle|closeParenthesis|adverbialPronoun|pronominalAdverb|relativeParticle|negativeParticle|suspensionPoints|exclamativePoint|relativePronoun|emphaticPronoun|cardinalNumeral|numeralFraction|personalPronoun|openParenthesis|negativePronoun|allusivePronoun|definiteArticle|diminutiveNoun|genericNumeral|futureParticle|circumposition|invertedComma|generalAdverb|deficientVerb|interjection|postposition|questionMark|adjective-na|relationNoun|conjunction|adjective-i|punctuation|preposition|adposition|determiner|commonNoun|properNoun|adjective|semiColon|plainVerb|lightVerb|auxiliary|particle|mainVerb|numeral|article|pronoun|adverb|symbol|letter|bullet|copula|colon|point|comma|modal|slash|verb|noun)(;(interrogativeMultiplicativeNumeral|indefiniteMultiplicativeNumeral|interrogativeRelativePronoun|interrogativeCardinalNumeral|interrogativeOrdinalNumeral|reflexivePossessivePronoun|presentParticipleAdjective|irreflexivePersonalPronoun|fusedPrepositionDeterminer|possessiveRelativePronoun|indefiniteCardinalNumeral|indefiniteOrdinalNumeral|reflexivePersonalPronoun|subordinatingConjunction|interrogativeDeterminer|fusedPrepositionPronoun|pastParticipleAdjective|coordinatingConjunction|demonstrativeDeterminer|affixedPersonalPronoun|fusedPronounAuxiliary|strongPersonalPronoun|exclamativeDeterminer|multiplicativeNumeral|interrogativeParticle|demonstrativePronoun|coordinationParticle|indefiniteDeterminer|unclassifiedParticle|possessiveDeterminer|interrogativePronoun|conditionalParticle|prepositionalAdverb|compoundPreposition|comparativeParticle|distinctiveParticle|possessiveAdjective|superlativeParticle|reflexiveDeterminer|affirmativeParticle|weakPersonalPronoun|participleAdjective|presentativePronoun|possessiveParticle|infinitiveParticle|relativeDeterminer|existentialPronoun|generalizationWord|qualifierAdjective|exclamativePronoun|conditionalPronoun|possessivePronoun|collectivePronoun|reciprocalPronoun|indefinitePronoun|impersonalPronoun|indefiniteArticle|fusedPreposition|ordinalAdjective|partitiveArticle|closeParenthesis|adverbialPronoun|pronominalAdverb|relativeParticle|negativeParticle|suspensionPoints|exclamativePoint|relativePronoun|emphaticPronoun|cardinalNumeral|numeralFraction|personalPronoun|openParenthesis|negativePronoun|allusivePronoun|definiteArticle|diminutiveNoun|genericNumeral|futureParticle|circumposition|invertedComma|generalAdverb|deficientVerb|interjection|postposition|questionMark|adjective-na|relationNoun|conjunction|adjective-i|punctuation|preposition|adposition|determiner|commonNoun|properNoun|adjective|semiColon|plainVerb|lightVerb|auxiliary|particle|mainVerb|numeral|article|pronoun|adverb|symbol|letter|bullet|copula|colon|point|comma|modal|slash|verb|noun))*"
            },
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#POS"
          },
          {
            "name": "label",
            "type": "string",
            "title": "label for this row",
            "description": "A human readable label for the row.",
            "rdfProperty": "http://www.w3.org/2000/01/rdf-schema#label"
          },
          {
            "name": "language_id",
            "type": "string",
            "title": "language identifier",
            "description": "Identifier for the language for comparison across PMST data sets"
          }
        ],
        "primaryKey": [
          "cell_id"
        ]
      },
      "rdfType": "https://www.paralex-standard.org/paralex_ontology.xml#Cell"
    },
    {
      "name": "features-values",
      "type": "table",
      "title": "Grammatical features values",
      "path": "pmst-komsaikul_features.csv",
      "scheme": "file",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "schema": {
        "name": "features-values-schema",
        "fields": [
          {
            "name": "value_id",
            "type": "string",
            "title": "Grammatical Feature value identifier",
            "description": "Identifier for the grammatical feature value (as found in the cell)",
            "constraints": {
              "required": true,
              "unique": true
            }
          },
          {
            "name": "label",
            "type": "string",
            "title": "label for this row",
            "description": "A human readable label for the row.",
            "rdfProperty": "http://www.w3.org/2000/01/rdf-schema#label"
          },
          {
            "name": "feature",
            "type": "string",
            "title": "feature",
            "description": "The name of the dimension of this feature, eg. case, tense, modality, voice, force, gender, evidentiality, person, number, polarity...",
            "constraints": {
              "required": true
            },
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#feature"
          },
          {
            "name": "unimorph",
            "type": "string",
            "title": "Cell/feature value in unimorph format",
            "description": "The cell or feature value, written following the unimorph schema",
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#unimorph"
          },
          {
            "name": "language_id",
            "type": "string",
            "title": "language identifier",
            "description": "Identifier for the language for comparison across PMST data sets"
          }
        ],
        "primaryKey": [
          "value_id"
        ]
      },
      "rdfType": "https://www.paralex-standard.org/paralex_ontology.xml#FeatureValue"
    },
    {
      "name": "forms",
      "type": "table",
      "title": "Inflected forms",
      "path": "pmst-komsaikul_forms.csv",
      "scheme": "file",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "schema": {
        "name": "forms-schema",
        "fields": [
          {
            "name": "form_id",
            "type": "string",
            "title": "Form table row identifiers",
            "description": "These identifiers are specific to form, lexeme, cell triples.",
            "constraints": {
              "required": true,
              "unique": true
            }
          },
          {
            "name": "lexeme",
            "type": "string",
            "title": "Reference to a lexeme identifier",
            "description": "Lexeme identifiers must be unique to paradigms.",
            "constraints": {
              "required": true
            },
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#lexeme"
          },
          {
            "name": "cell",
            "type": "string",
            "title": "Reference to a cell identifier",
            "description": "The set of feature values as would appear in a gloss, separated by dots, eg. prs.ind.1sg or f.pl",
            "constraints": {
              "required": true
            },
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#cell"
          },
          {
            "name": "source_form",
            "type": "string",
            "title": "source form with verb stem and/or segmentation",
            "description": "The form as provided in the source with the lexical verb stem (if relevant) and/or with segmentation according to orthography"
          },
          {
            "name": "orth_form",
            "type": "string",
            "title": "Inflected form (orthographic)",
            "description": "The form, given orthographically",
            "missingValues": [
              "#DEF#",
              "#MISSING#"
            ],
            "constraints": {
              "pattern": "(ch|ei|hm|ng|ui|-|a|e|h|i|k|m|n|s|t|u|Σ)+"
            },
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#orth_form"
          },
          {
            "name": "analysed_orth_form",
            "type": "string",
            "title": "Inflected form with analysis, such as segmentation markers (orthographic)",
            "description": "The form, given orthographically, with markers for analysis.",
            "missingValues": [
              "#DEF#",
              "#MISSING#"
            ],
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#analysed_orth_form"
          },
          {
            "name": "phon_form",
            "type": "string",
            "title": "Inflected form (phonemic or phonetic)",
            "description": "The form, given in phonemic or phonetic notation, with sounds separated by spaces",
            "missingValues": [
              "#DEF#",
              "#MISSING#"
            ],
            "constraints": {
              "pattern": "(m̥|tʃ|ei|ui|h|k|m|n|s|t|ŋ|a|e|i|u|Σ)( (m̥|tʃ|ei|ui|h|k|m|n|s|t|ŋ|a|e|i|u|Σ))*"
            },
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#phon_form"
          },
          {
            "name": "analysed_phon_form",
            "type": "string",
            "title": "Inflected form with analysis, such as segmentation markers (phonemic or phonetic)",
            "description": "The form, given in phonemic or phonetic notation, with sounds separated by spaces, and analysis markers.",
            "missingValues": [
              "#DEF#",
              "#MISSING#"
            ],
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#analysed_phon_form"
          },
          {
            "name": "epistemic_tag",
            "type": "string",
            "title": "Tags for epistemic status",
            "description": "Identifies sets of forms with the same epistemic status.",
            "constraints": {
              "pattern": "(generated|elicited)(\\|(generated|elicited))*"
            },
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#epistemic_tag"
          },
          {
            "name": "variants_tag",
            "type": "string",
            "title": "Tags for form variants",
            "description": "Identifies sets of forms used by specific groups of speakers. Eg. dialectal variants.",
            "constraints": {
              "pattern": "(sociolect_var|dialect_var|unspecified|informal|formal)(\\|(sociolect_var|dialect_var|unspecified|informal|formal))*"
            },
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#variants_tag"
          },
          {
            "name": "analysis_tag",
            "type": "string",
            "title": "Tags for marking separate analyses",
            "description": "Identifies sets of forms which are related by the same analysis. Eg: forms from two distinct sources, or a more phonetic and a more phonological transcription.",
            "constraints": {
              "pattern": "(mult_exponence|variable_order|fusion)(\\|(mult_exponence|variable_order|fusion))*"
            },
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#analysis_tag"
          },
          {
            "name": "overabundance_tag",
            "type": "string",
            "title": "Tags for overabundant forms",
            "description": "Identifies sets of overabundant forms. For example, overabundant forms across lexemes might belong to a series of regular and irregular forms, or a series of short and long forms, etc.",
            "constraints": {
              "pattern": "(optional_future|optional_plural)(\\|(optional_future|optional_plural))*"
            },
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#overabundance_tag"
          },
          {
            "name": "source",
            "type": "string",
            "title": "Source",
            "description": "Reference to a specific source (bibtex key). If used, the dataset should comprise a .bib file where the keys are referenced.",
            "rdfProperty": "https://www.paralex-standard.org/paralex_ontology.xml#source"
          },
          {
            "name": "page",
            "type": "string",
            "title": "page number in source",
            "description": "Indicates page number in source file (if known)"
          },
          {
            "name": "language_id",
            "type": "string",
            "title": "language identifier",
            "description": "Identifier for the language for comparison across PMST data sets"
          }
        ],
        "primaryKey": [
          "form_id"
        ],
        "foreignKeys": [
          {
            "fields": [
              "cell"
            ],
            "reference": {
              "resource": "cells",
              "fields": [
                "cell_id"
              ]
            }
          },
          {
            "fields": [
              "lexeme"
            ],
            "reference": {
              "resource": "lexemes",
              "fields": [
                "lexeme_id"
              ]
            }
          }
        ]
      },
      "rdfType": "https://www.paralex-standard.org/paralex_ontology.xml#Form"
    },
    {
      "name": "graphemes",
      "type": "table",
      "title": "Graphemes inventory",
      "path": "pmst-komsaikul_graphemes.csv",
