      "type": "table",
      "title": "Sound inventory with distinctive features",
      "path": "pmst-komsaikul_sounds.csv",
      "scheme": "file",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "schema": {
        "name": "sounds-schema",
        "fields": [
          {
            "name": "sound_id",
            "type": "string",
            "title": "sound representation",
            "description": "These identifiers are specific to sounds.",
            "constraints": {
