                "possessiveRelativePronoun",
                "ordinalAdjective",
                "collectivePronoun",
                "commonNoun",
                "infinitiveParticle",
                "comparativeParticle",
                "partitiveArticle",
                "invertedComma",
                "lightVerb",
                "emphaticPronoun",
                "distinctiveParticle",
                "genericNumeral",
                "possessiveAdjective",
                "reflexivePossessivePronoun",
                "colon",
                "coordinationParticle",
